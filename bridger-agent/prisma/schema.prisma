generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Greet {
  id Int @id @default(autoincrement())
  name String?
}

model Transaction {
  id                  String   @id @default(uuid())
  clientId            String   @map("client_id")
  qbId                String?  @map("qb_id")
  accountId           String?  @map("account_id")
  amount              Float
  createdAt           DateTime @default(now()) @map("created_at")
  bankDesc            String   @map("bank_desc")
  vendor              String?  @map("vendor")
  categoryId          String?   @map("category_id")
  confidenceCategory  Float?   @map("confidence_category")
  confidenceVendor    Float?   @map("confidence_vendor")
  reviewStatus        String @default("NONE") @map("review_status")

  // Relations
  client            Client   @relation(fields: [clientId], references: [id])
  clientCategory    ClientCategory? @relation(fields: [clientId, categoryId], references: [clientId, categoryId])

  @@index([clientId])
  @@index([clientId, categoryId])
}

model Client {
  id                String   @id @default(uuid())
  name              String
  description       String?
  joinedAt          DateTime @default(now()) @map("joined_at")
  confidenceThreshold Float    @map("confidence_setting")

  // Relations
  transactions      Transaction[]
  categories        ClientCategory[]
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?

  // Relations
  clients     ClientCategory[]
}

model ClientCategory {
  clientId   String   @map("client_id")
  categoryId String   @map("category_id")
  addedAt    DateTime @default(now()) @map("added_at")
  removedAt  DateTime? @map("removed_at")

  // Composite primary key for join table
  client     Client   @relation(fields: [clientId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  // Relations
  transactions Transaction[] 

  @@id([clientId, categoryId])
}
